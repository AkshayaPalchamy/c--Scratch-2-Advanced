using System;

public class BitWiseOperator
{
    public static void Main(string[] args)
    {
        int value = int.Parse(Console.ReadLine());

        int x = 0;

        for (int i = 0; i < value; i++)
        {
            string statement = Console.ReadLine();

            if (statement.Contains("++"))
            {
                x++;
            }
            else
            {
                x--;
            }
        }

        Console.WriteLine(x); 
    }
}
